# API Gateway Configuration
VITE_API_GATEWAY_URL=https://api.example.com/v1

# App Configuration
VITE_APP_NAME=CloudBox
VITE_DEFAULT_VIEW=grid

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_RAG=true

# API Endpoint Paths
VITE_AUTH_PATH=/auth/login
VITE_REGISTER_PATH=/auth/register
VITE_FILES_PATH=/storage/files
VITE_SEARCH_PATH=/storage/search
VITE_ANALYTICS_PATH=/storage/analytics
VITE_RAG_QUERY_PATH=/rag/query
